{
  "manifest_version": 3,
  "name": "Open Seed",
  "version": "0.1.0",
  "description": "Task automation that learns by watching you work.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/brain.js",
        "src/seed.js",
        "src/tree.js",
        "src/ui.js"
      ],
      "css": ["styles/badge.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Open Seed"
  }
}
